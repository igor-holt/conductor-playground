{
  "name": "genesis-conductor-monorepo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.27.0",
  "scripts": {
    "build": "pnpm -r --if-present build",
    "dev:operator-web": "pnpm --filter @genesis/operator-web dev",
    "dev:chatgpt-mcp": "pnpm --filter @genesis/chatgpt-mcp dev",
    "dev:worker": "pnpm --filter @genesis/retraining-worker dev",
    "lint": "pnpm run lint:root && pnpm -r --if-present lint",
    "lint:root": "eslint eslint.config.mjs",
    "typecheck": "pnpm run typecheck:root && pnpm -r --if-present typecheck",
    "typecheck:root": "tsc -p tsconfig.json --noEmit",
    "test": "pnpm run test:ts && pnpm run test:py && pnpm run test:notebooks",
    "test:ts": "pnpm --filter @genesis/contracts build && pnpm --filter @genesis/auth build && pnpm --filter @genesis/capsule build && pnpm -r --if-present test",
    "test:py": "uv run --project packages/puf-harness pytest packages/puf-harness/tests",
    "test:notebooks": "python3 scripts/check_notebooks.py",
    "secret-scan": "python3 scripts/secret_scan.py",
    "format:check": "prettier --check .",
    "verify": "pnpm lint && pnpm typecheck && pnpm test && pnpm secret-scan"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.5.2",
    "eslint": "^9.39.1",
    "globals": "^16.4.0",
    "prettier": "^3.6.2",
    "tsup": "^8.5.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.2",
    "vitest": "^3.2.4"
  }
}
