{
  "name": "@genesis/genesis-cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "genesis-conductor": "dist/index.js"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
